{
  "name": "deep-research-assistant",
  "version": "1.0.0",
  "description": "An intelligent research agent with ambiguity detection and clarification capabilities that automates comprehensive deep research workflows",
  "keywords": [
    "ai",
    "research",
    "agent",
    "openai",
    "automation",
    "query-processing",
    "information-retrieval"
  ],
  "homepage": "https://github.com/kaushik2901/deep-research-assistant#readme",
  "bugs": {
    "url": "https://github.com/kaushik2901/deep-research-assistant/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kaushik2901/deep-research-assistant.git"
  },
  "license": "MIT",
  "author": "Your Name <your.email@example.com>",
  "main": "dist/index.js",
  "bin": {
    "deep-research": "dist/index.js"
  },
  "scripts": {
    "start": "node dist/index.js",
    "dev": "set NODE_OPTIONS=\"--no-warnings=ExperimentalWarning\" && ts-node src/index.ts",
    "build": "tsc",
    "clean": "rimraf dist",
    "prebuild": "npm run clean",
    "postbuild": "cp -r src/templates dist/templates && echo '#!/usr/bin/env node' > dist/index.js.tmp && cat dist/index.js >> dist/index.js.tmp && mv dist/index.js.tmp dist/index.js && chmod +x dist/index.js",
    "prepack": "npm run build",
    "lint": "eslint src/ --ext .ts",
    "lint:fix": "eslint src/ --ext .ts --fix",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@openai/agents": "^0.0.7",
    "@tavily/core": "^0.5.11",
    "chalk": "^5.6.0",
    "dotenv": "^16.5.0",
    "inquirer": "^12.9.3",
    "log-symbols": "^7.0.1",
    "ora": "^8.2.0",
    "zod": "^3.25.64"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/inquirer": "^9.0.9",
    "@types/node": "^24.0.1",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "prettier": "^3.8.4",
    "rimraf": "^6.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ]
}
